{
  "mcpServers": {
    "dotmcp-assembly": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "DotMcp.Assembly/DotMcp.Assembly.csproj",
        "--configuration",
        "Release"
      ],
      "cwd": "."
    },
    "dotmcp-io": {
      "command": ".venv/bin/python",
      "args": ["DotMcp.IO/server.py"],
      "cwd": "."
    },
    "dotmcp-fetch": {
      "command": ".venv/bin/python",
      "args": ["DotMcp.Fetch/server.py"],
      "cwd": "."
    },
    "dotmcp-terminal": {
      "command": ".venv/bin/python",
      "args": ["DotMcp.Terminal/server.py"],
      "cwd": "."
    },
    "dotmcp-caldav": {
      "url": "http://127.0.0.1:8000/mcp",
      "headers": {
        "X-CalDAV-URL": "{{CALDAV_URL}}",
        "X-CalDAV-Username": "{{CALDAV_USERNAME}}",
        "X-CalDAV-Password": "{{CALDAV_PASSWORD}}"
      }
    }
  }
}
